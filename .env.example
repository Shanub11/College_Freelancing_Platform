# =============================================================
# CollegeGig Environment Variables Reference
# =============================================================
# 
# VITE_ prefix = bundled into frontend JS = PUBLICLY VISIBLE
# Only put non-secret config here (URLs, public keys, DSNs).
#
# Server secrets (API secret keys, webhook secrets, encryption keys)
# must NEVER have VITE_ prefix. Set them ONLY in:
# Convex Dashboard → Settings → Environment Variables
# =============================================================

# ── Frontend Variables (safe to be public) ──────────────────
# Your Convex deployment URL
VITE_CONVEX_URL=https://your-deployment.convex.cloud

# Razorpay PUBLIC key ID only (NOT the secret)
VITE_RAZORPAY_KEY_ID=rzp_test_xxxxxxxxxxxx

# PostHog analytics public key
VITE_POSTHOG_KEY=phc_xxxxxxxxxxxxxxxxxxxx

# Sentry DSN (public, safe to expose)
VITE_SENTRY_DSN=https://xxxx@xxxx.ingest.sentry.io/xxxx

# ── Convex CLI Variables (local dev only) ───────────────────
# These are used by the Convex CLI, never bundled in frontend
CONVEX_DEPLOY_KEY=
CONVEX_DEPLOYMENT=

# ── SERVER-SIDE SECRETS ─────────────────────────────────────
# The following must NEVER be VITE_ prefixed.
# Set them in Convex Dashboard → Settings → Environment Variables
# NEVER put them in this file or any .env file committed to git.
#
# RAZORPAY_KEY_ID=rzp_live_xxxx          (server-side duplicate)
# RAZORPAY_KEY_SECRET=xxxx               (secret — server only)
# RAZORPAY_WEBHOOK_SECRET=xxxx           (secret — server only)
# BREVO_API_KEY=xxxx                     (secret — server only)
# CONVEX_SITE_URL=https://collegegig.in  (used in email links)
# SENTRY_DSN=xxxx                        (server-side Sentry)
# MESSAGE_ENCRYPTION_KEY=xxxx            (64-char hex — server only)
